# AssetFlow — environment variables
# Copy this file to .env and fill in the real values. Never commit .env.

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL)
DB_NAME=assetflow
DB_USER=root
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=3306

# Media
MEDIA_URL=/media/
